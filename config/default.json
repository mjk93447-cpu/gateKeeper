  },
  "models": {
    "detector_path": "models/detector.onnx",
    "detector_checkpoint": "betty0/pcb-defect-detection",
    "ocr_model": "en_PP-OCRv4_mobile_rec",
    "ocr_model_dir": "models/ocr",
    "detector_input_size": [640, 640],
    "ocr_relative_roi": {
      "x": 0.0,
      "y": 0.0,
      "width": 1.0,
      "height": 1.0
    },
    "manifest": "models/manifest.json"
  },
  "logging": {
    "sqlite_path": "logs/gatekeeper.sqlite3",
    "jsonl_path": "logs/inspection.jsonl",
    "overlay_dir": "overlays"
  },
  "alarm": {
    "enabled": true,
    "repeat_seconds": 1.5,
